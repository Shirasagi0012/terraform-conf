# Terraform state & backup
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Terraform working directory cache
.terraform/

# Terraform crash logs
crash.log

# Terraform plan output files (if you save them)
*.plan
plan.out
plan.txt
tfplan

# Local-only variable files containing secrets
*.tfvars
*.auto.tfvars
# Provide an example/template instead
!terraform.tfvars.example
!*template.tfvars
!*example.tfvars

# Backend config with secrets (if you ever create one)
backend.secret.hcl
backend.conf

# Override experiment files
override.tf
override.tf.json
*_override.tf

# SSH keys & sensitive material
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.pem
*.key
private_key.pem

# Environment files
.env
.env.*

# Editor / OS junk (optional; team agreed)
.vscode/
.idea/
*.swp
.DS_Store

# Logs / temp
*.log
tmp/

cf-terraforming

# Generated platform artifacts
platforms/pve-dormintory/.generated/*
!platforms/pve-dormintory/.generated/.gitkeep
